---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Heading from "~/components/Heading.astro";
import Catalogue from "~/assets/files/catalogue.pdf";
import { Picture } from "astro:assets";

// Images
import VignetteCatalogue from "~/assets/images/vignette-catalogue.png";
---

<Layout>
	<Section>
		<Heading>
			<h2 slot="heading-title" class="font-black text-brand-green h2">Catalogue</h2>
			<p slot="heading-content">Retrouvez les hydrolats, leur conditionnement et les prix 
			<br/>dans le catalogue ci-dessous, téléchargeable en PDF : </p>
		</Heading>

		<div>
			<p class="text-center">
				<a href="/catalogue.pdf" target="_blank">
					<Picture
						class:list={"mx-auto"}
						src={VignetteCatalogue}
						height={200}
						formats={["avif", "webp"]}
						alt="A description of my image."
						loading={"eager"}
						fetchpriority={"high"}
					/>
					<button type="submit" class="button button-green group !px-8">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							fill="none"
							viewBox="0 0 24 24"
							stroke-width="1.5"
							stroke="currentColor"
							class="size-5 -rotate-45 -mt-1 inline-block mr-1 group-hover:rotate-0 transition duration-300"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5"
							></path>
						</svg>
						Catalogue 2026
					</button>
				</a>
			</p>
		</div>

	</Section>
</Layout>
